{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  // src/llm/gemini.ts is dormant (kept for reference, not imported anywhere);
  // its @google/generative-ai dependency was removed with the Ollama migration
  "exclude": ["node_modules", "dist", "src/llm/gemini.ts"]
}
